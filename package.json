{
  "name": "cloud-in-a-box",
  "version": "0.0.0",
  "description": "Your cloud in a box",
  "author": "Joohyun Park",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "webpack serve --config ./config/webpack.config.js --env mode=development",
    "build": "webpack --config ./config/webpack.config.js --env mode=production",
    "preview": "yarn build && http-server ./dist -o",
    "lint": "eslint ./src",
    "lint:fix": "eslint --fix ./src",
    "format": "prettier --write ./src"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/polyfill": "^7.12.1",
    "@babel/preset-env": "^7.29.0",
    "babel-loader": "^9.2.1",
    "clean-webpack-plugin": "^4.0.0",
    "compression-webpack-plugin": "^10.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.11.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "file-loader": "^6.2.0",
    "html-loader": "^4.2.0",
    "html-webpack-plugin": "^5.6.6",
    "http-server": "^14.1.1",
    "mini-css-extract-plugin": "^2.10.0",
    "prettier": "^3.8.1",
    "style-loader": "^3.3.4",
    "webpack": "^5.105.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.3"
